// Accent palette per step — vibrant, unique per question
const ACCENTS = [
  { h: '#a78bfa', glow: 'rgba(167,139,250,0.25)', soft: 'rgba(167,139,250,0.08)' },
  { h: '#fb923c', glow: 'rgba(251,146,60,0.25)',  soft: 'rgba(251,146,60,0.08)'  },
