                display: 'inline-flex', alignItems: 'center', gap: '4px',
                padding: '4px 10px',
                borderRadius: '14px',
                background: dark ? `${tag.color}18` : `${tag.color}14`,
                border: `1px solid ${tag.color}33`,
                fontSize: '11px', fontWeight: 700,
                color: dark ? `${tag.color}` : tag.color,
              }}>
