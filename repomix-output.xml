            border: avatar === a ? 'none' : `1px solid ${dark ? 'rgba(255,255,255,0.1)' : '#e2e8f0'}`,
            cursor: 'pointer',
            boxShadow: avatar === a ? '0 4px 12px rgba(99,102,241,0.4)' : 'none',
          }}>{a}</button>
