                  background: v.done ? (dark ? 'rgba(34,197,94,0.15)' : '#dcfce7') : (dark ? 'rgba(251,191,36,0.15)' : '#fef9c3'),
                  color: v.done ? (dark ? '#86efac' : '#16a34a') : (dark ? '#fcd34d' : '#b45309'),
                  fontSize: 11, padding: '2px 8px', borderRadius: 99,
                }}>{v.done ? '✅ مكتمل' : '⏳ معلق'}</span>
