import { storage } from './lib/storage';

// src/App.tsx
import { useState, useEffect, useCallback } from 'react';
import Navbar from './components/Navbar';
import Home from './pages/Home';
import Medicines from './pages/Medicines';
import Health from './pages/Health';
import Symptoms from './pages/Symptoms';
import Calendar from './pages/Calendar';
import Settings from './pages/Settings';
import MedicalRecords from './pages/MedicalRecords';
import AIAssistant from './pages/AIAssistant';
import Achievements from './components/Achievements';
import Vaccines from './pages/Vaccines';
import MedicalHistory from './pages/MedicalHistory';
import ReminderAlert from './components/ReminderAlert';
import EmergencyButton from './components/EmergencyButton';
import VoiceCommand from './components/VoiceCommand';
import Notes from './pages/Notes';
import HealthDigest from './pages/HealthDigest';
import WaterReminderNotif from './components/WaterReminderNotif';
import FamilyPortal from './pages/FamilyPortal';
import FamilyHome from './pages/FamilyHome';
import AuthScreen from './pages/AuthScreen';
import SplashScreen from './components/SplashScreen';
import NotificationCenter, { useUnreadCount } from './components/NotificationCenter';
import OnboardingQuiz from './components/OnboardingQuiz';
import { useWaterReminder } from './hooks/useWaterReminder';
import { AIProvider } from './context/AIContext';
import { FamilyProvider } from './context/FamilyContext';
import { AuthProvider, useAuth } from './context/AuthContext';
import { useFamily } from './context/FamilyContext';
import {
  isGranted,
  startWaterReminder,
  startAIReminder,
  scheduleMedReminders,
} from './services/NotificationService';

// ─────────────────────────────────────────────────────────────
export type Theme = 'light' | 'dark';

export type Page =
  | 'home' | 'medicines' | 'health' | 'symptoms' | 'calendar'
  | 'settings' | 'records' | 'ai' | 'achievements' | 'vaccines'
  | 'history' | 'notes' | 'digest' | 'family';

const ONBOARDING_KEY = 'onboarding_done';
const getOnboardingKey = (u: string) => `${ONBOARDING_KEY}_${u}`;
const getThemeKey      = (u: string) => `theme_${u}`;

// ─────────────────────────────────────────────────────────────
function AppInner() {
  const { user }          = useAuth();
  const { currentMember } = useFamily();

  const [page,           setPage]           = useState<Page>('home');
  const [theme,          setTheme]          = useState<Theme>('light');
  const [showSplash,     setShowSplash]     = useState(true);
  const [showNotifPanel, setShowNotifPanel] = useState(false);
  const [showOnboarding, setShowOnboarding] = useState(false);

  const unreadCount = useUnreadCount(currentMember?.id ?? '');
  useWaterReminder();

  // ─── عند تغيير المستخدم ──────────────────────────────────
  useEffect(() => {
    if (!user) return;
    setPage('home');
    setShowNotifPanel(false);

    // ✅ افتراضي نهاري — dark فقط إذا حُفظ صراحةً
    const saved = storage.get(getThemeKey(user.username));
    setTheme(saved === 'dark' ? 'dark' : 'light');

    // عرض الاستبيان إذا لم يُكتمل بعد
    const done = storage.get(getOnboardingKey(user.username));
    setShowOnboarding(!done);
  }, [user?.username]);

  // ─── تشغيل الإشعارات ──────────────────────────────────────
  useEffect(() => {
    if (isGranted()) {
      startWaterReminder();
      startAIReminder();
      scheduleMedReminders();
    }
  }, []);

  // ─── حفظ الثيم ────────────────────────────────────────────
  useEffect(() => {
    if (user?.username) storage.set(getThemeKey(user.username), theme);
  }, [theme, user?.username]);

  // ─── دوال ─────────────────────────────────────────────────
  const handleSplashFinish    = useCallback(() => setShowSplash(false), []);
  const handleOpenOnboarding  = useCallback(() => setShowOnboarding(true), []);
  const handleThemeToggle     = useCallback(() => setTheme(t => t === 'dark' ? 'light' : 'dark'), []);
  const handleNavigate        = useCallback((p: string) => setPage(p as Page), []);

  const handleOnboardingDone  = useCallback(() => {
    if (user?.username) storage.set(getOnboardingKey(user.username), 'true');
    setShowOnboarding(false);
  }, [user?.username]);

  // ─── شاشات ما قبل الدخول ──────────────────────────────────
  if (showSplash) return <SplashScreen onFinish={handleSplashFinish} />;
  if (!user)      return <AuthScreen theme={theme} />;

  // ─── تحديد الصفحة ─────────────────────────────────────────
  const dark = theme === 'dark';

  const renderPage = () => {
    switch (page) {
      case 'home':      return <Home theme={theme} />;
      case 'medicines': return <Medicines      theme={theme} />;
      case 'health':    return <Health         theme={theme} />;
      case 'symptoms':  return <Symptoms       theme={theme} />;
      case 'calendar':  return <Calendar       theme={theme} />;
      case 'settings':  return <Settings theme={theme} setTheme={setTheme} onEditProfile={handleOpenOnboarding} />;
      case 'records':   return <MedicalRecords theme={theme} />;
      case 'ai':        return <AIAssistant    theme={theme} />;
      case 'achievements': return <Achievements theme={theme} />;
      case 'vaccines':  return <Vaccines       theme={theme} />;
      case 'history':   return <MedicalHistory theme={theme} />;
      case 'notes':     return <Notes          theme={theme} />;
      case 'digest':    return <HealthDigest   theme={theme} />;
      case 'family':    return currentMember
        ? <FamilyHome   theme={theme} />
        : <FamilyPortal theme={theme} />;
      default:          return <Home theme={theme} />;
    }
  };

  return (
    <div style={{ minHeight: '100vh', background: dark ? '#0f172a' : '#f0f9ff', position: 'relative' }}>

      {/* ✅ الاستبيان */}
      {showOnboarding && (
        <OnboardingQuiz
          username={user.username}
          onFinish={handleOnboardingDone}
          onSkip={handleOnboardingDone}
        />
      )}

      <ReminderAlert />
      <WaterReminderNotif />

      <div className="page-enter" key={page}>{renderPage()}</div>

      <Navbar currentPage={page} setCurrentPage={setPage} theme={theme} />

      {showNotifPanel && <NotificationCenter onClose={() => setShowNotifPanel(false)} />}

      {/* الأزرار العائمة */}
      <div style={{ position: 'fixed', left: 12, bottom: 90, display: 'flex', flexDirection: 'column', gap: 10, zIndex: 400 }}>

        {/* 🔔 الإشعارات */}
        <button
          onClick={() => setShowNotifPanel(v => !v)}
          aria-label="الإشعارات"
          style={{
            width: 44, height: 44, borderRadius: '50%',
            background: dark ? 'rgba(30,41,59,0.95)' : 'rgba(255,255,255,0.95)',
            border: `1.5px solid ${dark ? 'rgba(99,102,241,0.4)' : 'rgba(2,132,199,0.30)'}`,
            boxShadow: '0 4px 16px rgba(0,0,0,0.15)',
            cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center',
            fontSize: 20, position: 'relative',
          }}
        >
          🔔
          {unreadCount > 0 && (
            <span style={{
              position: 'absolute', top: -4, right: -4,
              background: '#ef4444', color: '#fff', fontSize: 10, fontWeight: 700,
              borderRadius: '50%', width: 18, height: 18,
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              border: `2px solid ${dark ? '#0f172a' : '#ffffff'}`,
            }}>
              {unreadCount > 9 ? '9+' : unreadCount}
            </span>
          )}
        </button>

        <VoiceCommand onNavigate={handleNavigate} onThemeToggle={handleThemeToggle} />
        <EmergencyButton />
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
function AppWithFamily() {
  const { user } = useAuth();
  return (
    <FamilyProvider username={user?.username ?? null}>
      <AIProvider><AppInner /></AIProvider>
    </FamilyProvider>
  );
}

export default function App() {
  return (
    <AuthProvider><AppWithFamily /></AuthProvider>
  );
}
</file>

<file path="src/index.css">
@tailwind base;
@tailwind components;
@tailwind utilities;

@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap');

/* =============================================
   NEON IONIC HEALTH APP — DESIGN SYSTEM v3.0
   ============================================= */

:root {
  --p:     #818cf8;   /* indigo neon */
  --p2:    #6366f1;
  --s:     #22d3ee;   /* cyan neon */
  --acc:   #f472b6;   /* pink neon */
  --gold:  #fbbf24;
  --lime:  #a3e635;
  --mint:  #34d399;
  --nav-h: 72px;

  /* Glow intensities */
  --glow-purple: 0 0 20px rgba(99,102,241,0.6), 0 0 60px rgba(99,102,241,0.2);
  --glow-cyan:   0 0 20px rgba(34,211,238,0.6),  0 0 60px rgba(34,211,238,0.2);
  --glow-pink:   0 0 20px rgba(244,114,182,0.6), 0 0 60px rgba(244,114,182,0.2);
  --glow-gold:   0 0 20px rgba(251,191,36,0.6),  0 0 60px rgba(251,191,36,0.2);
  --glow-mint:   0 0 20px rgba(52,211,153,0.6),  0 0 60px rgba(52,211,153,0.2);
}

* {
  font-family: 'Cairo', sans-serif;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  -webkit-tap-highlight-color: transparent;
}

body {
  background: #050510;
  color: #e2e8f0;
  min-height: 100vh;
  overflow-x: hidden;
}

/* =============================================
   ANIMATED BACKGROUND — Layered Orbs
   ============================================= */

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 15% 10%, rgba(99,102,241,0.18) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 85% 85%, rgba(34,211,238,0.14) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 50% 50%, rgba(244,114,182,0.07) 0%, transparent 70%),
    radial-gradient(ellipse 30% 30% at 80% 15%, rgba(163,230,53,0.06) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    radial-gradient(circle at 1px 1px, rgba(255,255,255,0.015) 1px, transparent 0);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* =============================================
   GLASS CARDS
   ============================================= */

.glass-card {
  background: rgba(255,255,255,0.035);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 24px;
  position: relative;
  overflow: hidden;
  transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
  margin-bottom: 12px;
}

.glass-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.25) 40%,
    rgba(129,140,248,0.4) 60%,
    transparent 100%);
}

.glass-card:active {
  transform: scale(0.98);
}

/* =============================================
   NEON CARDS
   ============================================= */

.neon-card {
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20px;
  padding: 1rem;
  text-align: center;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.neon-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20px;
  background: linear-gradient(135deg,
    rgba(129,140,248,0.08) 0%,
    rgba(34,211,238,0.08) 100%);
  opacity: 0;
  transition: opacity 0.3s;
}

.neon-card:hover::before,
.neon-card:active::before { opacity: 1; }

.neon-card:hover {
  border-color: rgba(129,140,248,0.4);
  box-shadow: 0 0 30px rgba(99,102,241,0.2), inset 0 0 30px rgba(99,102,241,0.04);
  transform: translateY(-3px) scale(1.01);
}

/* =============================================
   BUTTONS — NEON SERIES
   ============================================= */

.btn-neon {
  background: linear-gradient(135deg, #6366f1 0%, #7c3aed 100%);
  color: white;
  border: none;
  border-radius: 16px;
  padding: 0.85rem 1.5rem;
  font-weight: 700;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 4px 24px rgba(99,102,241,0.5), inset 0 1px 0 rgba(255,255,255,0.2);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.3px;
}

.btn-neon::after {
  content: '';
  position: absolute;
  top: 0; left: -120%;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
  transform: skewX(-20deg);
  transition: left 0.6s ease;
}

.btn-neon:hover::after { left: 160%; }

.btn-neon:hover {
  box-shadow: 0 8px 35px rgba(99,102,241,0.7), 0 0 0 1px rgba(129,140,248,0.4);
  transform: translateY(-2px);
}

.btn-neon:active {
  transform: translateY(0) scale(0.97);
  box-shadow: 0 2px 12px rgba(99,102,241,0.4);
}

.btn-neon-cyan {
  background: linear-gradient(135deg, #0891b2, #0e7490);
  box-shadow: 0 4px 24px rgba(6,182,212,0.5);
}
.btn-neon-cyan:hover {
  box-shadow: 0 8px 35px rgba(34,211,238,0.7);
}

.btn-neon-green {
  background: linear-gradient(135deg, #059669, #047857);
  box-shadow: 0 4px 24px rgba(16,185,129,0.5);
}
.btn-neon-green:hover {
  box-shadow: 0 8px 35px rgba(52,211,153,0.7);
}

.btn-neon-red {
  background: linear-gradient(135deg, #dc2626, #b91c1c);
  box-shadow: 0 4px 24px rgba(239,68,68,0.5);
}

.btn-neon-pink {
  background: linear-gradient(135deg, #db2777, #be185d);
  box-shadow: 0 4px 24px rgba(244,114,182,0.5);
}

.btn-neon-gold {
  background: linear-gradient(135deg, #d97706, #b45309);
  box-shadow: 0 4px 24px rgba(251,191,36,0.5);
}

/* =============================================
   GLASS INPUTS
   ============================================= */

.input-glass {
  width: 100%;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 14px;
  padding: 0.85rem 1rem;
  color: #e2e8f0;
  font-size: 0.95rem;
  text-align: right;
  transition: all 0.3s ease;
  outline: none;
  font-family: 'Cairo', sans-serif;
}

.input-glass::placeholder { color: rgba(148,163,184,0.45); }

.input-glass:focus {
  border-color: rgba(129,140,248,0.6);
  background: rgba(99,102,241,0.07);
  box-shadow:
    0 0 0 3px rgba(99,102,241,0.15),
    0 0 25px rgba(99,102,241,0.12),
    inset 0 1px 0 rgba(255,255,255,0.05);
}

/* =============================================
   NEON PROGRESS BAR
   ============================================= */

.progress-neon {
  height: 8px;
  background: rgba(255,255,255,0.04);
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.04);
}

.progress-neon-fill {
  height: 100%;
  border-radius: 20px;
  background: linear-gradient(90deg, var(--p2), var(--s));
  box-shadow: 0 0 12px rgba(99,102,241,0.9), 0 0 30px rgba(34,211,238,0.4);
  transition: width 0.8s cubic-bezier(0.34,1.56,0.64,1);
  position: relative;
}

.progress-neon-fill::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 24px; height: 100%;
  background: rgba(255,255,255,0.5);
  border-radius: 20px;
  filter: blur(6px);
  animation: progress-shine 2s ease-in-out infinite;
}

/* =============================================
   BOTTOM NAVBAR — MOBILE FIRST
   ============================================= */

.navbar-glass {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: var(--nav-h);
  background: rgba(5,5,16,0.88);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-top: 1px solid rgba(255,255,255,0.05);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 8px;
}

.navbar-glass::before {
  content: '';
  position: absolute;
  top: 0; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg,
    transparent,
    rgba(129,140,248,0.5) 40%,
    rgba(34,211,238,0.5) 60%,
    transparent);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  padding: 8px 12px;
  border-radius: 18px;
  border: none;
  background: transparent;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  color: rgba(148,163,184,0.55);
  font-size: 10px;
  font-weight: 600;
  font-family: 'Cairo', sans-serif;
  min-width: 54px;
  position: relative;
}

.nav-item .nav-icon {
  font-size: 22px;
  line-height: 1;
  transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  filter: grayscale(0.3) opacity(0.6);
}

.nav-item.active {
  color: #ffffff;
}

.nav-item.active .nav-icon {
  transform: translateY(-5px) scale(1.25);
  filter: drop-shadow(0 0 8px rgba(129,140,248,0.9)) grayscale(0);
}

.nav-item.active::before {
  content: '';
  position: absolute;
  top: 2px;
  width: 36px; height: 3px;
  background: linear-gradient(90deg, var(--p2), var(--s));
  border-radius: 0 0 6px 6px;
  box-shadow: 0 0 14px rgba(99,102,241,0.9);
  animation: nav-glow 2s ease-in-out infinite;
}

.nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 2px;
  width: 6px; height: 6px;
  background: var(--p);
  border-radius: 50%;
  box-shadow: 0 0 10px var(--p);
  animation: dot-pulse 1.5s ease-in-out infinite;
}

.nav-item:not(.active):active {
  transform: scale(0.9);
  color: rgba(148,163,184,0.8);
}

/* =============================================
   MORE MENU — DRAWER OVERLAY
   ============================================= */

.more-overlay {
  position: fixed;
  inset: 0;
  z-index: 90;
  background: rgba(0,0,0,0);
  pointer-events: none;
  transition: background 0.4s ease;
}

.more-overlay.open {
  background: rgba(0,0,8,0.75);
  backdrop-filter: blur(8px);
  pointer-events: all;
}

.more-drawer {
  position: fixed;
  bottom: var(--nav-h);
  left: 0; right: 0;
  z-index: 95;
  background: rgba(8,8,22,0.97);
  border: 1px solid rgba(255,255,255,0.07);
  border-bottom: none;
  border-radius: 32px 32px 0 0;
  padding: 16px 16px 20px;
  transform: translateY(110%);
  transition: transform 0.45s cubic-bezier(0.34,1.3,0.64,1);
  max-height: 70vh;
  overflow-y: auto;
}

.more-drawer::before {
  content: '';
  display: block;
  width: 44px; height: 4px;
  background: rgba(255,255,255,0.15);
  border-radius: 4px;
  margin: 0 auto 20px;
}

.more-drawer::after {
  content: '';
  position: absolute;
  top: 0; left: 15%; right: 15%;
  height: 1px;
  background: linear-gradient(90deg,
    transparent, rgba(129,140,248,0.6), rgba(34,211,238,0.6), transparent);
}

.more-drawer.open {
  transform: translateY(0);
}

.drawer-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.drawer-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px 8px;
  border-radius: 20px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  position: relative;
  overflow: hidden;
  font-family: 'Cairo', sans-serif;
}

.drawer-item::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20px;
  opacity: 0;
  transition: opacity 0.3s;
}

.drawer-item:active {
  transform: scale(0.93);
}

.drawer-item .d-icon {
  font-size: 30px;
  line-height: 1;
  transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
}

.drawer-item .d-label {
  font-size: 12px;
  font-weight: 700;
  color: rgba(148,163,184,0.8);
  transition: color 0.3s;
}

/* Coloured variants per item */
.drawer-item.color-cyan {
  border-color: rgba(34,211,238,0.15);
}
.drawer-item.color-cyan:active {
  background: rgba(34,211,238,0.1);
  border-color: rgba(34,211,238,0.4);
  box-shadow: 0 0 20px rgba(34,211,238,0.2);
}

.drawer-item.color-pink {
  border-color: rgba(244,114,182,0.15);
}
.drawer-item.color-pink:active {
  background: rgba(244,114,182,0.1);
  border-color: rgba(244,114,182,0.4);
  box-shadow: 0 0 20px rgba(244,114,182,0.2);
}

.drawer-item.color-gold {
  border-color: rgba(251,191,36,0.15);
}
.drawer-item.color-gold:active {
  background: rgba(251,191,36,0.1);
  border-color: rgba(251,191,36,0.4);
  box-shadow: 0 0 20px rgba(251,191,36,0.2);
}

.drawer-item.color-mint {
  border-color: rgba(52,211,153,0.15);
}
.drawer-item.color-mint:active {
  background: rgba(52,211,153,0.1);
  border-color: rgba(52,211,153,0.4);
  box-shadow: 0 0 20px rgba(52,211,153,0.2);
}

.drawer-item.color-purple {
  border-color: rgba(139,92,246,0.15);
}
.drawer-item.color-purple:active {
  background: rgba(139,92,246,0.1);
  border-color: rgba(139,92,246,0.4);
  box-shadow: 0 0 20px rgba(139,92,246,0.2);
}

.drawer-item.color-red {
  border-color: rgba(239,68,68,0.15);
}
.drawer-item.color-red:active {
  background: rgba(239,68,68,0.1);
  border-color: rgba(239,68,68,0.4);
  box-shadow: 0 0 20px rgba(239,68,68,0.2);
}

/* =============================================
   LUXURY PAGE HEADERS
   ============================================= */

.luxury-header {
  padding: 2.2rem 1.2rem 3.2rem;
  position: relative;
  overflow: hidden;
}

.luxury-header::after {
  content: '';
  position: absolute;
  bottom: -2px; left: 0; right: 0;
  height: 44px;
  background: #050510;
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  z-index: 2;
}

.luxury-header .orb-1 {
  position: absolute;
  top: -60px; right: -60px;
  width: 200px; height: 200px;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  z-index: 1;
}

.luxury-header .orb-2 {
  position: absolute;
  bottom: -40px; left: -40px;
  width: 150px; height: 150px;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
  z-index: 1;
}

.luxury-header-content {
  position: relative;
  z-index: 3;
}

/* =============================================
   NEON TIMER
   ============================================= */

.timer-neon {
  font-size: 2.4rem;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
  letter-spacing: 4px;
  background: linear-gradient(135deg, #f472b6 0%, #fb923c 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 12px rgba(244,114,182,0.6));
}

.timer-neon.safe {
  background: linear-gradient(135deg, var(--p) 0%, var(--s) 100%);
  filter: drop-shadow(0 0 12px rgba(99,102,241,0.6));
}

/* =============================================
   TEXT GRADIENTS
   ============================================= */

.text-gradient {
  background: linear-gradient(135deg, var(--p) 0%, var(--s) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-gradient-gold {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-gradient-pink {
  background: linear-gradient(135deg, #f472b6 0%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-gradient-mint {
  background: linear-gradient(135deg, #34d399 0%, #22d3ee 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* =============================================
   BADGES
   ============================================= */

.badge-neon {
  display: inline-flex; align-items: center;
  padding: 3px 12px; border-radius: 20px;
  font-size: 11px; font-weight: 700;
  background: rgba(99,102,241,0.12);
  color: #a5b4fc;
  border: 1px solid rgba(99,102,241,0.3);
}
.badge-green {
  background: rgba(16,185,129,0.12); color: #6ee7b7;
  border-color: rgba(16,185,129,0.3);
}
.badge-red {
  background: rgba(239,68,68,0.12); color: #fca5a5;
  border-color: rgba(239,68,68,0.3);
}
.badge-gold {
  background: rgba(251,191,36,0.12); color: #fde68a;
  border-color: rgba(251,191,36,0.3);
}
.badge-cyan {
  background: rgba(34,211,238,0.12); color: #67e8f9;
  border-color: rgba(34,211,238,0.3);
}

/* =============================================
   ALERTS
   ============================================= */

.alert-glass {
  background: rgba(99,102,241,0.08);
  border: 1px solid rgba(99,102,241,0.22);
  border-radius: 16px; padding: 1rem;
  backdrop-filter: blur(10px);
}
.alert-glass-green {
  background: rgba(16,185,129,0.08);
  border-color: rgba(16,185,129,0.22);
}
.alert-glass-red {
  background: rgba(239,68,68,0.08);
  border-color: rgba(239,68,68,0.22);
}
.alert-glass-gold {
  background: rgba(251,191,36,0.08);
  border-color: rgba(251,191,36,0.22);
}

/* =============================================
   ACHIEVEMENTS
   ============================================= */

.achievement-neon {
  background: rgba(251,191,36,0.07);
  border: 1px solid rgba(251,191,36,0.2);
  border-radius: 18px; padding: 1rem;
  text-align: center;
  transition: all 0.3s ease;
}
.achievement-neon:hover {
  background: rgba(251,191,36,0.14);
  box-shadow: 0 0 30px rgba(251,191,36,0.2);
  transform: translateY(-3px);
}
.achievement-neon.locked {
  background: rgba(255,255,255,0.02);
  border-color: rgba(255,255,255,0.05);
  filter: grayscale(1); opacity: 0.35;
}

/* =============================================
   MODAL OVERLAY
   ============================================= */

.modal-overlay {
  background: rgba(0,0,10,0.85);
  backdrop-filter: blur(14px);
}

/* =============================================
   ANIMATIONS
   ============================================= */

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes glow-pulse {
  0%,100% { box-shadow: 0 0 8px rgba(99,102,241,0.3); }
  50%      { box-shadow: 0 0 30px rgba(99,102,241,0.8), 0 0 60px rgba(99,102,241,0.3); }
}

@keyframes float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-10px); }
}

@keyframes emergency-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(239,68,68,0.8); }
  70%  { box-shadow: 0 0 0 18px rgba(239,68,68,0); }
  100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); }
}

@keyframes nav-glow {
  0%,100% { opacity: 1; box-shadow: 0 0 10px rgba(99,102,241,0.8); }
  50%      { opacity: 0.6; box-shadow: 0 0 20px rgba(34,211,238,0.9); }
}

@keyframes dot-pulse {
  0%,100% { transform: scale(1); opacity: 1; }
  50%      { transform: scale(1.6); opacity: 0.5; }
}

@keyframes progress-shine {
  0%,100% { opacity: 0.5; }
  50%      { opacity: 1; }
}

@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

@keyframes orb-drift {
  0%,100% { transform: translate(0,0) scale(1); }
  33%      { transform: translate(30px,-20px) scale(1.05); }
  66%      { transform: translate(-20px,15px) scale(0.97); }
}

@keyframes neon-shimmer {
  0%   { background-position: -300% center; }
  100% { background-position: 300% center; }
}

/* Utility animation classes */
.page-enter      { animation: fadeUp 0.4s ease-out both; }
.glow-pulse      { animation: glow-pulse 2s ease-in-out infinite; }
.float-anim      { animation: float 3.5s ease-in-out infinite; }
.emergency-btn   { animation: emergency-pulse 1.5s ease-in-out infinite; }
.spin-slow       { animation: spin-slow 8s linear infinite; }

/* =============================================
   SCROLLBAR
   ============================================= */

::-webkit-scrollbar { width: 3px; height: 3px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
  background: linear-gradient(var(--p2), var(--s));
  border-radius: 10px;
}

/* =============================================
   SAFE AREA (iPhone notch)
   ============================================= */

.pb-nav {
  padding-bottom: calc(var(--nav-h) + 12px);
}

/* =============================================
   IONIC BLUE ENERGY BAR ANIMATION
   ============================================= */

@keyframes ionicPulse {
  0%   { opacity: 1; transform: scale(1); box-shadow: 0 0 8px #00f0ff, 0 0 16px #00f0ff; }
  50%  { opacity: 0.6; transform: scale(1.5); box-shadow: 0 0 16px #00f0ff, 0 0 32px #00f0ff, 0 0 48px #0080ff; }
  100% { opacity: 1; transform: scale(1); box-shadow: 0 0 8px #00f0ff, 0 0 16px #00f0ff; }
}

@keyframes ionicFlow {
  0%   { background-position: -200% center; }
  100% { background-position: 200% center; }
}
