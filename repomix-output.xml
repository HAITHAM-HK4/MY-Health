      { label: 'A-',  value: 'A-',       icon: '🔴' },
      { label: 'B+',  value: 'B+',       icon: '🟠' },
      { label: 'B-',  value: 'B-',       icon: '🟠' },
      { label: 'O+',  value: 'O+',       icon: '🔵' },
      { label: 'O-',  value: 'O-',       icon: '🔵' },
      { label: 'AB+', value: 'AB+',      icon: '🟣' },
      { label: 'AB-', value: 'AB-',      icon: '🟣' },
      { label: 'لا أعرف', value: 'unknown', icon: '❓' },
